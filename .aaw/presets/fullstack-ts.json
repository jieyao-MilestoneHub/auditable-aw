{
  "$schema": "../schema/project.schema.json",
  "name": "fullstack-typescript",
  "description": "TypeScript fullstack: Vite React + Fastify (uses official CLIs)",

  "init": {
    "baseDir": "workspace",
    "steps": [
      {
        "name": "Create workspace directory",
        "command": "mkdir -p workspace",
        "creates": "workspace"
      },
      {
        "name": "Create frontend with Vite",
        "command": "npm create vite@latest workspace/frontend -- --template react-ts",
        "creates": "workspace/frontend"
      },
      {
        "name": "Create backend",
        "command": "mkdir -p workspace/backend/src && cd workspace/backend && npm init -y",
        "creates": "workspace/backend"
      },
      {
        "name": "Install backend dependencies",
        "command": "cd workspace/backend && npm install fastify @fastify/cors typescript @types/node tsx",
        "creates": "workspace/backend/node_modules"
      },
      {
        "name": "Create shared types",
        "command": "mkdir -p workspace/shared/types workspace/shared/schemas",
        "creates": "workspace/shared"
      },
      {
        "name": "Create contracts directory",
        "command": "mkdir -p workspace/contracts",
        "creates": "workspace/contracts"
      }
    ]
  },

  "roles": {
    "frontend": {
      "name": "Frontend Developer",
      "path": "workspace/frontend",
      "framework": "react",
      "canRead": ["workspace/shared/**", "workspace/contracts/**"],
      "canWrite": ["workspace/frontend/**"],
      "forbidden": ["workspace/backend/src/services/**", "workspace/backend/src/routes/**"],
      "commands": {
        "dev": "cd workspace/frontend && npm run dev",
        "build": "cd workspace/frontend && npm run build",
        "test": "cd workspace/frontend && npm test",
        "lint": "cd workspace/frontend && npm run lint"
      }
    },
    "backend": {
      "name": "Backend Developer",
      "path": "workspace/backend",
      "framework": "fastify",
      "canRead": ["workspace/shared/**", "workspace/contracts/**"],
      "canWrite": ["workspace/backend/**"],
      "forbidden": ["workspace/frontend/src/components/**", "workspace/frontend/src/pages/**"],
      "commands": {
        "dev": "cd workspace/backend && npm run dev",
        "build": "cd workspace/backend && npm run build",
        "test": "cd workspace/backend && npm test"
      }
    },
    "integrator": {
      "name": "API Integrator",
      "path": "workspace/contracts",
      "canRead": ["workspace/frontend/src/**", "workspace/backend/src/**", "workspace/shared/**"],
      "canWrite": ["workspace/contracts/**", "workspace/shared/**"],
      "forbidden": ["workspace/frontend/src/components/**", "workspace/backend/src/services/**"],
      "commands": {
        "validate": "npx tsc --noEmit -p workspace/contracts/tsconfig.json",
        "test": "npm run test:integration"
      }
    }
  },

  "shared": {
    "contracts": "workspace/contracts",
    "types": "workspace/shared/types",
    "schemas": "workspace/shared/schemas"
  },

  "docs": {
    "frontend": "https://vitejs.dev/guide/",
    "backend": "https://fastify.dev/docs/latest/",
    "typescript": "https://www.typescriptlang.org/docs/"
  },

  "collaboration": {
    "mode": "strict",
    "lockTimeout": 300,
    "requireAck": true
  }
}
