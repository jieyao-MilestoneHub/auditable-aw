{
  "$schema": "../../../schemas/security-profile.schema.json",
  "name": "angular",
  "extends": "languages/typescript",
  "description": "Angular projects",

  "permissions": {
    "ask": [
      "Bash(ng generate:*)",
      "Bash(ng build:*)",
      "Bash(ng serve:*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "if [[ \"$CLAUDE_TOOL_INPUT_FILE_PATH\" =~ \\.component\\.ts$ ]]; then npx eslint --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true; fi",
          "timeout": 30
        }]
      }
    ]
  }
}
